  "impact_texts": [
    {
      "block": 1,
      "start_offset": 0,
      "end_offset": 6,
      "text": "UM COMPUTADOR DE 2 MIL ANOS?"
    },
    {
      "block": 2,
      "start_offset": 10,
      "end_offset": 16,
      "text": "A MÁQUINA GREGA QUE PREVIA O DESTINO"
    },
    {
      "block": 5,
      "start_offset": 20,
      "end_offset": 25,
      "text": "UMA TECNOLOGIA DE MILÊNIOS À FRENTE"
    },
    {
      "block": 6,
      "start_offset": 26,
      "end_offset": 31,
      "text": "O PRIMEIRO COMPUTADOR ANALÓGICO"
    },
    {
      "block": 8,
      "start_offset": 38,
      "end_offset": 43,
      "text": "PODER E DESTINO NAS MÃOS DOS GREGOS"
    },
    {
      "block": 9,
      "start_offset": 44,
      "end_offset": 49,
      "text": "POR QUE ELA DESAPARECEU?"
    },
    {
      "block": 14,
      "start_offset": 65,
      "end_offset": 70,
      "text": "O PASSADO REESCREVE O FUTURO."
    }
  ],
  "block_phrases": [
    {
      "block": 1,
      "phrase": "Imagine um computador."
    },
    {
      "block": 2,
      "phrase": "O que você faria se encontrasse algo assim?"
    },
    {
      "block": 3,
      "phrase": "No ano de 1900, em meio às águas cristalinas perto da ilha grega de Anticítera,"
    },
    {
      "block": 4,
      "phrase": "Ninguém imaginava que aquela relíquia deteriorada era, na verdade, um portal para um passado inimaginável."
    },
    {
      "block": 5,
      "phrase": "E o que se revelou?"
    },
    {
      "block": 6,
      "phrase": "Era um computador analógico."
    },
    {
      "block": 7,
      "phrase": "Mas não era só isso."
    },
    {
      "block": 8,
      "phrase": "Na Grécia Antiga, o céu era um livro aberto onde se tentava ler o destino."
    },
    {
      "block": 9,
      "phrase": "Mas então, surge a grande questão:"
    },
    {
      "block": 10,
      "phrase": "Existem algumas teorias intrigantes."
    },
    {
      "block": 11,
      "phrase": "Outra possibilidade é que o declínio da civilização greco-romana,"
    },
    {
      "block": 12,
      "phrase": "Hoje, o Mecanismo de Anticítera continua a ser estudado,"
    },
    {
      "block": 13,
      "phrase": "O Mecanismo de Anticítera não era apenas um relógio ou um calendário."
    },
    {
      "block": 14,
      "phrase": "É inacreditável pensar que há dois mil anos existia uma máquina que fazia o que hoje consideramos alta tecnologia."
    }
  ],
