{
    "106.mp3": [
        {
            "start": 0.0,
            "end": 5.8,
            "text": "Mas a genialidade real, estava em algo que quase ninguém percebe olhando de fora."
        },
        {
            "start": 6.3,
            "end": 11.88,
            "text": "O ângulo, o canat precisava ser inclinado o suficiente para água correr,"
        },
        {
            "start": 11.88,
            "end": 14.48,
            "text": "mas não podia ser inclinado demais."
        },
        {
            "start": 14.48,
            "end": 18.76,
            "text": "Uma corrente muito forte poderia desgastar as paredes internas,"
        },
        {
            "start": 18.76,
            "end": 21.96,
            "text": "carregar sedimentos e danificar o túnel."
        },
        {
            "start": 21.96,
            "end": 25.8,
            "text": "Por outro lado, se a inclinação fosse pequena demais,"
        },
        {
            "start": 26.0,
            "end": 30.28,
            "text": "a água perderia força e pararia antes de chegar a cidade."
        },
        {
            "start": 30.6,
            "end": 33.04,
            "text": "Então, cada metro importava."
        },
        {
            "start": 33.04,
            "end": 38.56,
            "text": "Um erro pequeno no começo, podia virar um problema enorme que lômetros depois."
        },
        {
            "start": 39.04,
            "end": 42.44,
            "text": "E isso torna a obra ainda mais impressionante."
        },
        {
            "start": 42.44,
            "end": 45.56,
            "text": "Porque não estamos falando de cavar qualquer túnel."
        },
        {
            "start": 45.56,
            "end": 50.44,
            "text": "Estamos falando de abrir uma estrutura subterrânea longa, estreita,"
        },
        {
            "start": 50.44,
            "end": 56.04,
            "text": "funcional e precisa em um ambiente seco, quente e difícil."
        },
        {
            "start": 56.04,
            "end": 61.199999999999996,
            "text": "Confirre a mente assim, com esforço humano, com observação,"
        },
        {
            "start": 61.199999999999996,
            "end": 63.519999999999996,
            "text": "com experiência acumulada,"
        },
        {
            "start": 63.519999999999996,
            "end": 67.32,
            "text": "e principalmente com paciência."
        },
        {
            "start": 67.88,
            "end": 72.52,
            "text": "Hoje, a gente olha para grandes obras e pensa em máquinas gigantes,"
        },
        {
            "start": 72.52,
            "end": 77.44,
            "text": "mas ali, o que sustentava tudo era uma combinação de conhecimento prático"
        },
        {
            "start": 77.44,
            "end": 80.4,
            "text": "e respeito absoluto pelo terreno."
        },
        {
            "start": 80.56,
            "end": 83.76,
            "text": "Ele sabia um que a água não precisava ser forçada."
        },
        {
            "start": 83.76,
            "end": 85.96000000000001,
            "text": "Ela precisava ser guiada."
        }
    ],
    "107.mp3": [
        {
            "start": 0.0,
            "end": 5.26,
            "text": "E quando essa água finalmente chegava a superfície, o cenário mudava."
        },
        {
            "start": 5.26,
            "end": 8.5,
            "text": "Um lugar seco podia ganhar canais."
        },
        {
            "start": 8.5,
            "end": 11.5,
            "text": "Campos pudiam ser irrigados."
        },
        {
            "start": 11.5,
            "end": 14.1,
            "text": "Plantações pudiam crescer."
        },
        {
            "start": 14.1,
            "end": 16.46,
            "text": "Animais pudiam beber."
        },
        {
            "start": 16.46,
            "end": 19.5,
            "text": "Famílias pudiam armazenar água."
        },
        {
            "start": 19.5,
            "end": 22.3,
            "text": "Mercados pudiam surgir."
        },
        {
            "start": 22.3,
            "end": 28.7,
            "text": "E uma pequena comunidade podia deixar de ser temporária para se tornar permanent."
        },
        {
            "start": 28.9,
            "end": 33.16,
            "text": "É por isso que o canát, não era apenas uma obra hidráulica."
        },
        {
            "start": 33.16,
            "end": 36.4,
            "text": "Era uma obra de sobrevivência."
        },
        {
            "start": 36.4,
            "end": 42.1,
            "text": "A água que corria em baixo da terra aparecia na superfície como vida."
        },
        {
            "start": 42.1,
            "end": 46.2,
            "text": "Onde antes havia solo seco surgia cultivo."
        },
        {
            "start": 46.2,
            "end": 51.4,
            "text": "Um diante esavia distância e isolamento surgia comércio."
        },
        {
            "start": 51.4,
            "end": 55.6,
            "text": "Onde antes havia incerteza surgia rotina."
        },
        {
            "start": 55.6,
            "end": 61.1,
            "text": "E para quem vivia ali, aquele sistema não era uma curiosidade de engenharia."
        },
        {
            "start": 61.1,
            "end": 64.8,
            "text": "Era a diferença entre ficar e partir."
        },
        {
            "start": 64.8,
            "end": 67.8,
            "text": "Entre plantar e abandonar."
        },
        {
            "start": 67.8,
            "end": 71.0,
            "text": "Entre cidade e deserto."
        },
        {
            "start": 71.0,
            "end": 75.4,
            "text": "Mas existe uma parte dessa história que muita gente esquece."
        },
        {
            "start": 75.4,
            "end": 77.9,
            "text": "Um canát não era só túnel."
        },
        {
            "start": 77.9,
            "end": 80.0,
            "text": "Não era só excavação."
        },
        {
            "start": 80.0,
            "end": 83.4,
            "text": "Não era só água correndo de baixo da terra."
        },
        {
            "start": 83.5,
            "end": 86.80000000000001,
            "text": "Era também organização social."
        },
        {
            "start": 86.80000000000001,
            "end": 89.2,
            "text": "Porque alguém precisava construir."
        },
        {
            "start": 89.2,
            "end": 91.4,
            "text": "Alguém precisava manter."
        },
        {
            "start": 91.4,
            "end": 93.4,
            "text": "Alguém precisava limpar."
        },
        {
            "start": 93.4,
            "end": 95.9,
            "text": "Alguém precisava vigiar."
        },
        {
            "start": 95.9,
            "end": 102.0,
            "text": "E principalmente alguém precisava decidir como aquela água seria distribuída."
        },
        {
            "start": 102.0,
            "end": 106.30000000000001,
            "text": "Em uma região seca, água nunca é apenas água."
        },
        {
            "start": 106.30000000000001,
            "end": 108.30000000000001,
            "text": "Água é alimento."
        },
        {
            "start": 108.30000000000001,
            "end": 111.0,
            "text": "Água é terra produtiva."
        },
        {
            "start": 111.0,
            "end": 113.2,
            "text": "Água é permanência."
        },
        {
            "start": 113.2,
            "end": 115.4,
            "text": "Água é comercio."
        },
        {
            "start": 115.4,
            "end": 117.8,
            "text": "Água é poder."
        },
        {
            "start": 117.8,
            "end": 121.8,
            "text": "Quem controla água controla muito mais do que um recurso."
        },
        {
            "start": 121.8,
            "end": 124.2,
            "text": "Controla o ritmo da vida."
        },
        {
            "start": 124.2,
            "end": 126.6,
            "text": "Controla o tempo da colheita."
        },
        {
            "start": 126.6,
            "end": 132.0,
            "text": "Controla quem pode plantar onde pode plantar e por quanto tempo."
        },
        {
            "start": 132.0,
            "end": 135.2,
            "text": "Então, o canátis estava de baixo da terra."
        },
        {
            "start": 135.2,
            "end": 139.2,
            "text": "Mas seus efeitos apareciam em toda a sociedade."
        },
        {
            "start": 139.39999999999998,
            "end": 141.39999999999998,
            "text": "A engenharia era invisível."
        },
        {
            "start": 141.39999999999998,
            "end": 145.0,
            "text": "Mas o poder dela era impossível de ignorar."
        }
    ],
    "108.mp3": [
        {
            "start": 0.0,
            "end": 6.2,
            "text": "Talvez a parte mais impressionante dos canates, seja o contraste com a forma como a gente enxerga"
        },
        {
            "start": 6.2,
            "end": 8.22,
            "text": "grande sobra hoje."
        },
        {
            "start": 8.22,
            "end": 14.0,
            "text": "Um, hoje, quando pensamos em construção grandeiosa, pensamos em altura."
        },
        {
            "start": 14.0,
            "end": 24.94,
            "text": "Arrânea céus, pontezenórimis, torres de vidro, máquinas gigantes, concreto, aço, velocidade."
        },
        {
            "start": 24.94,
            "end": 33.94,
            "text": "Mas os canates eram oposto, eram baixos, eram lentos, eram estreitos, eram subterrâneos,"
        },
        {
            "start": 33.94,
            "end": 36.94,
            "text": "e quase ninguém via."
        },
        {
            "start": 36.94,
            "end": 41.02,
            "text": "Mesmo assim, podia uns sustentar uma cidade inteira."
        },
        {
            "start": 41.02,
            "end": 43.42,
            "text": "Essa é a grande virada."
        },
        {
            "start": 43.42,
            "end": 47.02,
            "text": "Nem toda a grande engenharia precisa aparecer."
        },
        {
            "start": 47.02,
            "end": 52.94,
            "text": "Algumas das obras mais importantes da história não foram feitas para serem admiradas,"
        },
        {
            "start": 52.94,
            "end": 55.94,
            "text": "foram feitas para funcionar."
        },
        {
            "start": 55.94,
            "end": 62.78,
            "text": "E funcionaram, porque respeitavam uma regra simples, não lutar contra a natureza quando era possível"
        },
        {
            "start": 62.78,
            "end": 65.06,
            "text": "trabalhar com ela."
        },
        {
            "start": 65.06,
            "end": 67.5,
            "text": "A água já queria descer."
        },
        {
            "start": 67.5,
            "end": 70.06,
            "text": "A gravidade já existia."
        },
        {
            "start": 70.06,
            "end": 72.94,
            "text": "O terreno já indicava o caminho."
        },
        {
            "start": 72.94,
            "end": 77.58,
            "text": "O papel humano foi entender isso e criaram uma passagem."
        },
        {
            "start": 77.58,
            "end": 79.34,
            "text": "Não era dominação."
        },
        {
            "start": 79.34,
            "end": 81.58,
            "text": "Era inteligência."
        },
        {
            "start": 81.58,
            "end": 85.66,
            "text": "Então, de forma simples, o canátif funcionava assim."
        },
        {
            "start": 85.66,
            "end": 91.38,
            "text": "Primeiro, os consultores procuravam água subterrânea em uma região mais alta."
        },
        {
            "start": 91.38,
            "end": 96.53999999999999,
            "text": "Depois, cavavam um posto principal até o cansar essa água."
        },
        {
            "start": 96.53999999999999,
            "end": 103.46,
            "text": "A partir da lhe abriam um túnel levemente inclinado em direção a área onde as pessoas viviam."
        },
        {
            "start": 103.46,
            "end": 110.82,
            "text": "Ao longo do caminho, criavam possos verticais para retirar terra, ventilar e fazer manutenção."
        },
        {
            "start": 110.82,
            "end": 114.94,
            "text": "A água seguia sozinha movida pela gravidade."
        },
        {
            "start": 114.94,
            "end": 124.41999999999999,
            "text": "Inufinado percurso aparecia na superfície para abastecer casas, campos, jardins, animais e reservatórios."
        },
        {
            "start": 124.41999999999999,
            "end": 126.22,
            "text": "Simples de explicar."
        },
        {
            "start": 126.22,
            "end": 128.82,
            "text": "Muito difícil de construir."
        },
        {
            "start": 128.82,
            "end": 131.94,
            "text": "E genial justamente por isso."
        },
        {
            "start": 131.94,
            "end": 137.5,
            "text": "Porque a solução não dependia de força bruta, dependia de precisão."
        },
        {
            "start": 137.5,
            "end": 141.22,
            "text": "No fim, os canátis mostram algo poderoso."
        },
        {
            "start": 141.22,
            "end": 147.7,
            "text": "As vezes, a construção mais importante de uma civilização não é aqui aparecem nas fotos."
        },
        {
            "start": 147.7,
            "end": 150.7,
            "text": "Não é aqui tem a faxada mais bonita."
        },
        {
            "start": 150.7,
            "end": 153.86,
            "text": "Não é aqui chega mais perto do céu."
        },
        {
            "start": 153.86,
            "end": 156.22,
            "text": "É aquela que ninguém vê."
        },
        {
            "start": 156.22,
            "end": 159.98,
            "text": "Aquela que passa em silêncio por baixo da terra."
        },
        {
            "start": 159.98,
            "end": 166.74,
            "text": "Aquela que sustenta a comida, a água, as casas e a vida cotidiana."
        },
        {
            "start": 166.74,
            "end": 169.42000000000002,
            "text": "O deserto parecia vazio."
        },
        {
            "start": 169.42000000000002,
            "end": 173.82000000000002,
            "text": "Mas por baixo dele existia uma máquina silenciosa."
        },
        {
            "start": 173.82000000000002,
            "end": 179.46,
            "text": "Uma máquina feita de pedra, cálculo, suor e gravidade."
        },
        {
            "start": 179.46,
            "end": 184.74,
            "text": "E talvez seja por isso que essa engenharia antiga ainda impressiona tanto."
        },
        {
            "start": 184.74,
            "end": 188.34,
            "text": "Porque ela não precisava gritar para mudar o mundo."
        },
        {
            "start": 188.34,
            "end": 191.70000000000002,
            "text": "Ela só precisava fazer a água chegar."
        },
        {
            "start": 191.7,
            "end": 196.26,
            "text": "Se você gosta de descobrir os detalhes escondidos por trás das maiores construções da"
        },
        {
            "start": 196.26,
            "end": 198.94,
            "text": "história, se inscreve no canal."
        },
        {
            "start": 198.94,
            "end": 202.14,
            "text": "Aqui, a gente não olha só para o monumento."
        },
        {
            "start": 202.14,
            "end": 205.7,
            "text": "A gente olha para o segredo que fez ele existir."
        },
        {
            "start": 205.7,
            "end": 207.54,
            "text": "E comenta aqui embaixo."
        },
        {
            "start": 207.54,
            "end": 211.06,
            "text": "Qual obra antiga você acha mais impressionante."
        },
        {
            "start": 211.06,
            "end": 213.01999999999998,
            "text": "Aquela que todo mundo vê."
        },
        {
            "start": 213.02,
            "end": 215.58,
            "text": "Ou aquela que fica escondida sustentando tudo."
        }
    ]
}