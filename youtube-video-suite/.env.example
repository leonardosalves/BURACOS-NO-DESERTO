# Aplicação
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
API_PORT=4000
WEB_PORT=3000

# Banco
DATABASE_URL=postgresql://video_suite:video_suite@localhost:5432/video_suite?schema=public

# Redis / filas
REDIS_URL=redis://localhost:6379

# Armazenamento S3 compatível / MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=video-suite
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
MINIO_CONSOLE_URL=http://localhost:9001

# IA e mídia
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
FISH_AUDIO_API_KEY=
HEYGEN_API_KEY=
ATLAS_CLOUD_API_KEY=

# Renderização
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
CHROME_EXECUTABLE_PATH=
REMOTION_LICENSE_KEY=free-license
HYPERFRAMES_RENDER_MODE=local

# Segurança
JWT_SECRET=troque-esta-chave
ENCRYPTION_KEY=troque-esta-chave-de-32-bytes
WEBHOOK_SECRET=troque-este-segredo
