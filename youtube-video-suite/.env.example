# Video Suite — Environment Example

# ── Database ──
DATABASE_URL=postgresql://videosuite:videosuite_dev@localhost:5432/videosuite

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── API ──
PORT=3001
NODE_ENV=development

# ── API Keys (optional — fallback to config_qanat.json) ──
# GEMINI_API_KEY=your-gemini-key
# FISH_SPEECH_API_URL=http://localhost:8080
# FISH_SPEECH_API_KEY=your-fish-speech-key
