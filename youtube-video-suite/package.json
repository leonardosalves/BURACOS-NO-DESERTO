{
  "name": "youtube-video-suite",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f",
    "db:studio": "pnpm --filter @video-suite/api prisma studio",
    "render:remotion": "pnpm --filter @video-suite/remotion-renderer render",
    "render:hyperframes": "pnpm --filter @video-suite/hyperframes-renderer render"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  }
}
