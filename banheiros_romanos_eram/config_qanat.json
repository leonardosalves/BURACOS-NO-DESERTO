    "block_phrases": [
        {
            "block": 1,
            "phrase": "Você sabia que ir ao banheiro na Roma Antiga podia literalmente te explodir?"
        },
        {
            "block": 2,
            "phrase": "Os famosos banheiros públicos romanos eram verdadeiras armadilhas mortais."
        },
        {
            "block": 3,
            "phrase": "Embaixo daqueles assentos de pedra fria, ficavam fossas profundas"
        },
        {
            "block": 4,
            "phrase": "Bastava uma faísca ou o calor de uma lâmpada"
        },
        {
            "block": 5,
            "phrase": "E se isso não bastasse, ratazanas gigantes"
        }
    ],
