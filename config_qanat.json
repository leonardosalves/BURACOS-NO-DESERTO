  "block_phrases": [
    {
      "block": 1,
      "phrase": "Por milênios, fomos ensinados que as pirâmides do Egito eram monumentos grandiosos, tumbas para faraós."
    },
    {
      "block": 2,
      "phrase": "Prepare-se para uma jornada que vai desvendar os véus da história oficial."
    },
    {
      "block": 3,
      "phrase": "A narrativa das pirâmides como meras tumbas, embora amplamente aceita, sempre teve suas lacunas."
    },
    {
      "block": 4,
      "phrase": "Uma das teorias mais fascinantes aponta para as pirâmides como verdadeiras usinas de energia."
    },
    {
      "block": 5,
      "phrase": "Indo além da energia, muitos estudiosos argumentam que as pirâmides funcionavam como observatórios cósmicos ou calendários gigantes."
    },
    {
      "block": 6,
      "phrase": "E se as pirâmides fossem ainda mais extraordinárias?"
    },
    {
      "block": 7,
      "phrase": "Talvez a verdade seja ainda mais complexa: e se as pirâmides não tivessem *um* propósito, mas múltiplos?"
    },
    {
      "block": 8,
      "phrase": "Recentemente, avanços tecnológicos como a muografia têm revelado segredos surpreendentes."
    },
    {
      "block": 9,
      "phrase": "A questão fundamental que permanece é: quem realmente construiu as pirâmides com tal sofisticação e conhecimento?"
    },
    {
      "block": 10,
      "phrase": "Em resumo, as pirâmides do Egito podem ter sido muito mais do que meras tumbas."
    },
    {
      "block": 11,
      "phrase": "A verdade é que as pirâmides continuam sendo um dos maiores enigmas da humanidade."
    },
    {
      "block": 12,
      "phrase": "Qual dessas teorias você acha mais convincente?"
    }
